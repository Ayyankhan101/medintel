# ────────────────────────────────────────────────────────────────────────────
# MedIntel — environment variables
#
# Copy this file to `.env.local` for local development.
# On Vercel, set these in Project → Settings → Environment Variables.
# ────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Local dev: use any Postgres (`docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16`).
# Vercel: provision a Neon database from the Vercel Marketplace — `DATABASE_URL` is set automatically.
DATABASE_URL="postgres://user:pass@host:5432/medintel?sslmode=require"

# NextAuth session encryption key. Generate with: `openssl rand -base64 32`
NEXTAUTH_SECRET="REPLACE_WITH_32_BYTE_BASE64_SECRET"

# Public URL of the deployed app. On Vercel, use your production domain.
NEXTAUTH_URL="http://localhost:3000"

# Groq API key for the medical triage pipeline (free tier at console.groq.com).
GROQ_API_KEY=""


# ── OPTIONAL — features degrade gracefully if missing ───────────────────────

# OpenAI is used only as a fallback if GROQ_API_KEY is unset.
# OPENAI_API_KEY=""

# Stripe escrow + Connect onboarding for doctor payouts.
# Without these, /api/escrow/* and /api/stripe/* will return errors.
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PLATFORM_ACCOUNT_ID=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Twilio Video for live consultations.
# Without these, /api/consultation/token returns 503.
# TWILIO_ACCOUNT_SID=""
# TWILIO_API_KEY_SID=""
# TWILIO_API_KEY_SECRET=""

# AWS S3 for voice upload + prescription file storage.
# Without these, only text intake works; file uploads fail.
# AWS_REGION="ap-south-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET=""

# Google Maps for nearby hospital lookup. Without it, mock Lahore data is returned.
# GOOGLE_MAPS_SERVER_KEY=""

# Resend transactional email. Without these, email notifications are no-ops
# (booking confirmations, prescription-ready, escrow-released, welcome).
# Get a key at https://resend.com/api-keys
# RESEND_API_KEY=""
# RESEND_FROM="MedIntel <noreply@medintel.app>"   # must be a verified sending domain;
                                                  # otherwise use the sandbox sender:
                                                  # "MedIntel <onboarding@resend.dev>"
# APP_URL="https://your-domain.vercel.app"        # optional — falls back to NEXTAUTH_URL

# Sentry error tracking. Without SENTRY_DSN, all error capture is a no-op.
# SENTRY_ORG + SENTRY_PROJECT + SENTRY_AUTH_TOKEN together enable source-map
# upload at build time — leave them unset to skip that step.
# SENTRY_DSN=""                                   # server-side DSN
# NEXT_PUBLIC_SENTRY_DSN=""                       # client-side DSN (usually same value)
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""                            # from https://sentry.io/settings/account/api/auth-tokens/
# SENTRY_TRACES_SAMPLE_RATE="0.1"                 # 10% of server txns traced
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"     # same on the client

# NADRA (Pakistan national ID) identity verification.
# Without this, patient registration fails closed in production.
# Set MOCK_KYC=true to bypass for non-production testing.
# NADRA_API_URL=""
# NADRA_API_KEY=""
# MOCK_KYC="true"

# PMDC (Pakistan Medical & Dental Council) doctor license verification.
# PMDC_API_URL=""
# PMDC_API_KEY=""
