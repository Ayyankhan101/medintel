generator client {
  provider = "prisma-client-js"
}

// Dev/demo: SQLite (zero setup — just run `npm run setup`)
// Production: see prisma/schema.prisma (PostgreSQL with enums).
// Keep models in this file aligned with the Postgres schema; SQLite-specific
// notes inline (no enums, no native JSON, no Decimal precision args).
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String    @unique
  passwordHash  String
  name          String?
  // role: PATIENT | DOCTOR | ADMIN
  role          String
  cnicNumber    String?   @unique
  medIntelCode  String?   @unique
  // kycStatus: PENDING | VERIFIED | REJECTED
  kycStatus     String    @default("PENDING")
  kycVerifiedAt DateTime?
  emailVerified        DateTime?
  emailVerifyToken     String?   @unique
  emailVerifyExpires   DateTime?
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  // Soft-delete marker. PII is anonymized in-place; regulated records retained.
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // CLINIC_ADMIN users belong to one clinic.
  clinicId String?
  clinic   Clinic? @relation("ClinicMembers", fields: [clinicId], references: [id])

  patient     Patient?
  doctor      Doctor?
  sessions    Session[]
  ownedClinic Clinic? @relation("ClinicOwner")
}

model Clinic {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  ownerUserId     String   @unique
  owner           User     @relation("ClinicOwner", fields: [ownerUserId], references: [id])
  // plan: STARTER | STANDARD | ENTERPRISE
  plan            String   @default("STARTER")
  minutesQuota    Int      @default(2000)
  minutesUsed     Int      @default(0)
  whatsappNumber  String?
  voiceNumber     String?
  brandColor      String?
  active          Boolean  @default(true)

  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  currentPeriodEnd     DateTime?
  quotaAlertLevel      Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members User[]         @relation("ClinicMembers")
  doctors Doctor[]
  usage   ClinicUsage[]
  invites ClinicInvite[]
}

model ClinicInvite {
  id         String    @id @default(cuid())
  clinicId   String
  clinic     Clinic    @relation(fields: [clinicId], references: [id])
  email      String
  token      String    @unique
  role       String    @default("DOCTOR")
  expiresAt  DateTime
  acceptedAt DateTime?
  invitedBy  String
  createdAt  DateTime  @default(now())

  @@unique([clinicId, email])
  @@index([clinicId, createdAt])
}

model ClinicUsage {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  channel   String
  minutes   Int
  meta      String?  // JSON-stringified for sqlite
  createdAt DateTime @default(now())

  @@index([clinicId, createdAt])
  @@index([clinicId, channel])
}

model Patient {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  dateOfBirth      DateTime?
  gender           String?
  address          String?
  emergencyContact String?

  medicalRecords MedicalRecord[]
  appointments   Appointment[]
  triages        Triage[]
  reviews        Review[]
}

model Triage {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id])
  transcript    String
  summary       String
  severityScore Int
  // severityLevel: ROUTINE | URGENT | CRITICAL
  severityLevel String
  department    String
  voiceFileUrl  String?
  createdAt     DateTime @default(now())

  @@index([patientId, createdAt])
}

model Doctor {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  licenseNumber   String    @unique
  specialization  String
  qualifications  String    @default("[]")
  yearsExperience Int
  bio             String?
  consultationFee Decimal
  stripeAccountId String?
  // kydStatus: PENDING | VERIFIED | REJECTED
  kydStatus       String    @default("PENDING")
  kydTier1At      DateTime?
  kydTier2At      DateTime?
  kydTier3At      DateTime?
  trustBadge      Boolean   @default(false)
  rating          Decimal?
  reviewCount     Int       @default(0)
  // JSON string: { days: [1..7], startHour, endHour, timezone }
  availability    String?

  // Doctor optionally belongs to a clinic (B2B model).
  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id])

  appointments Appointment[]
  reviews      Review[]

  @@index([clinicId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  expires      DateTime
}

model MedicalRecord {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  // type: ALLERGY | CHRONIC_MED | SURGERY | LAB_REPORT | PRESCRIPTION | NOTE
  type       String
  title      String
  content    String
  fileUrl    String?
  ocrText    String?
  recordedAt DateTime
  createdAt  DateTime @default(now())

  @@index([patientId, recordedAt])
}

model Appointment {
  id          String    @id @default(cuid())
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id])
  doctorId    String?
  doctor      Doctor?   @relation(fields: [doctorId], references: [id])
  // status: SCHEDULED | IN_PROGRESS | COMPLETED | CANCELLED | REFUNDED
  status      String    @default("SCHEDULED")
  scheduledAt DateTime
  completedAt DateTime?
  cancelledAt DateTime?

  voiceFileUrl     String?
  transcript       String?
  aiSummary        String?
  severityScore    Int?
  // severityLevel: ROUTINE | URGENT | CRITICAL
  severityLevel    String?
  department       String?

  prescriptionUrl  String?
  prescriptionText String?

  escrow    Escrow?
  note      ConsultationNote?
  review    Review?

  reminderSentAt     DateTime?
  recordingConsentAt DateTime?
  cancellationReason String?
  cancelledBy        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([doctorId])
}

model Review {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient     @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        Doctor      @relation(fields: [doctorId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())

  @@index([doctorId, createdAt])
}

model ConsultationNote {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  transcript    String
  subjective    String
  objective     String
  assessment    String
  plan          String
  // JSON-encoded string[] (SQLite has no array)
  icdHints      String      @default("[]")
  language      String      @default("en")
  modelUsed     String?
  approvedAt    DateTime?
  approvedBy    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Escrow {
  id                    String    @id @default(cuid())
  appointmentId         String    @unique
  appointment           Appointment @relation(fields: [appointmentId], references: [id])
  amount                Decimal
  currency              String    @default("PKR")
  // status: HELD | RELEASED | REFUNDED
  status                String    @default("HELD")
  stripePaymentIntentId String    @unique
  heldAt                DateTime  @default(now())
  releasedAt            DateTime?
  refundedAt            DateTime?
  refundReason          String?
  refundedAmount        Decimal?
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  action     String
  entityType String
  entityId   String
  metadata   String?  // JSON-stringified for sqlite
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model MedicalResource {
  id          String   @id @default(cuid())
  name        String
  // type: HOSPITAL | PHARMACY | OXYGEN | VENTILATOR | BLOOD_BANK | AMBULANCE
  type        String
  address     String
  latitude    Decimal
  longitude   Decimal
  phone       String?
  isAvailable Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model RateLimitBucket {
  id      String   @id
  count   Int      @default(0)
  resetAt DateTime

  @@index([resetAt])
}

model ProcessedStripeEvent {
  eventId   String   @id
  type      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
