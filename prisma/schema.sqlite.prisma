generator client {
  provider = "prisma-client-js"
}

// Dev/demo: SQLite (zero setup — just run `npm run setup`)
// Production: see prisma/schema.production.prisma (PostgreSQL with enums)
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String    @unique
  passwordHash  String
  name          String?
  // role: PATIENT | DOCTOR | ADMIN
  role          String
  cnicNumber    String?   @unique
  medIntelCode  String?   @unique
  // kycStatus: PENDING | VERIFIED | REJECTED
  kycStatus     String    @default("PENDING")
  kycVerifiedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient  Patient?
  doctor   Doctor?
  sessions Session[]
}

model Patient {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  dateOfBirth      DateTime?
  gender           String?
  address          String?
  emergencyContact String?

  medicalRecords MedicalRecord[]
  appointments   Appointment[]
  triages        Triage[]
}

model Triage {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id])
  transcript    String
  summary       String
  severityScore Int
  // severityLevel: ROUTINE | URGENT | CRITICAL
  severityLevel String
  department    String
  voiceFileUrl  String?
  createdAt     DateTime @default(now())

  @@index([patientId, createdAt])
}

model Doctor {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  licenseNumber   String    @unique
  specialization  String
  qualifications  String    @default("[]")
  yearsExperience Int
  bio             String?
  consultationFee Decimal
  stripeAccountId String?
  // kydStatus: PENDING | VERIFIED | REJECTED
  kydStatus       String    @default("PENDING")
  kydTier1At      DateTime?
  kydTier2At      DateTime?
  kydTier3At      DateTime?
  trustBadge      Boolean   @default(false)
  rating          Decimal?
  reviewCount     Int       @default(0)
  // JSON string: { days: [1..7], startHour, endHour, timezone }
  availability    String?

  appointments Appointment[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  expires      DateTime
}

model MedicalRecord {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  // type: ALLERGY | CHRONIC_MED | SURGERY | LAB_REPORT | PRESCRIPTION | NOTE
  type       String
  title      String
  content    String
  fileUrl    String?
  ocrText    String?
  recordedAt DateTime
  createdAt  DateTime @default(now())

  @@index([patientId, recordedAt])
}

model Appointment {
  id          String    @id @default(cuid())
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id])
  doctorId    String?
  doctor      Doctor?   @relation(fields: [doctorId], references: [id])
  // status: SCHEDULED | IN_PROGRESS | COMPLETED | CANCELLED | REFUNDED
  status      String    @default("SCHEDULED")
  scheduledAt DateTime
  completedAt DateTime?
  cancelledAt DateTime?

  voiceFileUrl     String?
  transcript       String?
  aiSummary        String?
  severityScore    Int?
  // severityLevel: ROUTINE | URGENT | CRITICAL
  severityLevel    String?
  department       String?

  prescriptionUrl  String?
  prescriptionText String?

  escrow    Escrow?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([doctorId])
}

model Escrow {
  id                    String    @id @default(cuid())
  appointmentId         String    @unique
  appointment           Appointment @relation(fields: [appointmentId], references: [id])
  amount                Decimal
  currency              String    @default("PKR")
  // status: HELD | RELEASED | REFUNDED
  status                String    @default("HELD")
  stripePaymentIntentId String    @unique
  heldAt                DateTime  @default(now())
  releasedAt            DateTime?
  refundedAt            DateTime?
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  action     String
  entityType String
  entityId   String
  metadata   String?  // JSON-stringified for sqlite
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model MedicalResource {
  id          String   @id @default(cuid())
  name        String
  // type: HOSPITAL | PHARMACY | OXYGEN | VENTILATOR | BLOOD_BANK | AMBULANCE
  type        String
  address     String
  latitude    Decimal
  longitude   Decimal
  phone       String?
  isAvailable Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}
