// Production schema — PostgreSQL
// To deploy: copy this file over schema.prisma, set DATABASE_URL to your PostgreSQL URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
  CLINIC_ADMIN
}

enum ClinicPlan {
  STARTER
  STANDARD
  ENTERPRISE
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AppointmentStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

/// Audit trail for security-sensitive actions: escrow release/refund,
/// prescription upload, KYC/KYD outcomes, doctor verification decisions,
/// appointment cancellations. Required for dispute resolution.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?           // user.id of whoever performed the action; null = system
  actorRole  String?           // PATIENT | DOCTOR | ADMIN | SYSTEM
  action     String            // e.g. "escrow.release", "kyd.approve"
  entityType String            // e.g. "Appointment", "Doctor"
  entityId   String
  metadata   Json?             // small structured context (amounts, reason, IP)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
}

enum SeverityLevel {
  ROUTINE
  URGENT
  CRITICAL
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

model User {
  id            String             @id @default(cuid())
  email         String             @unique
  phone         String             @unique
  passwordHash  String
  name          String?
  role          UserRole
  cnicNumber    String?            @unique
  medIntelCode  String?            @unique
  kycStatus     VerificationStatus @default(PENDING)
  kycVerifiedAt DateTime?
  emailVerified        DateTime?
  emailVerifyToken     String?   @unique
  emailVerifyExpires   DateTime?
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?

  // Soft-delete marker. PII is anonymized in-place; regulated records (Rx,
  // audit logs) are retained per Drugs Act 1976 / PMDC.
  deletedAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  // CLINIC_ADMIN users belong to one clinic.
  clinicId String?
  clinic   Clinic? @relation("ClinicMembers", fields: [clinicId], references: [id])

  patient    Patient?
  doctor     Doctor?
  sessions   Session[]
  ownedClinic Clinic? @relation("ClinicOwner")
}

model Clinic {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  ownerUserId     String     @unique
  owner           User       @relation("ClinicOwner", fields: [ownerUserId], references: [id])
  plan            ClinicPlan @default(STARTER)
  minutesQuota    Int        @default(2000)
  minutesUsed     Int        @default(0)
  whatsappNumber  String?
  voiceNumber     String?
  brandColor      String?
  active          Boolean    @default(true)

  // Stripe subscription
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  currentPeriodEnd     DateTime?

  // Highest quota-threshold alert already sent in the current period. Reset to 0 on invoice.paid.
  quotaAlertLevel Int @default(0)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  members   User[]   @relation("ClinicMembers")
  doctors   Doctor[]
  usage     ClinicUsage[]
  invites   ClinicInvite[]
}

model ClinicInvite {
  id        String    @id @default(cuid())
  clinicId  String
  clinic    Clinic    @relation(fields: [clinicId], references: [id])
  email     String
  token     String    @unique
  // Reserved for future role expansion (DOCTOR, CLINIC_STAFF, etc.)
  role      String    @default("DOCTOR")
  expiresAt DateTime
  acceptedAt DateTime?
  invitedBy String
  createdAt DateTime  @default(now())

  @@unique([clinicId, email])
  @@index([clinicId, createdAt(sort: Desc)])
}

model ClinicUsage {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  // channel: whatsapp | voice | web | scribe
  channel   String
  minutes   Int
  meta      Json?
  createdAt DateTime @default(now())

  @@index([clinicId, createdAt(sort: Desc)])
  @@index([clinicId, channel])
}

model Patient {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  dateOfBirth      DateTime?
  gender           String?
  address          String?
  emergencyContact String?

  medicalRecords MedicalRecord[]
  appointments   Appointment[]
  triages        Triage[]
  reviews        Review[]
}

model Triage {
  id            String        @id @default(cuid())
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id])
  transcript    String        @db.Text
  summary       String        @db.Text
  severityScore Int
  severityLevel SeverityLevel
  department    String
  voiceFileUrl  String?
  createdAt     DateTime      @default(now())

  @@index([patientId, createdAt(sort: Desc)])
}

model Doctor {
  id              String             @id @default(cuid())
  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id])
  licenseNumber   String             @unique
  specialization  String
  qualifications  String[]
  yearsExperience Int
  bio             String?
  consultationFee Decimal            @db.Decimal(10, 2)
  stripeAccountId String?
  kydStatus       VerificationStatus @default(PENDING)
  kydTier1At      DateTime?
  kydTier2At      DateTime?
  kydTier3At      DateTime?
  trustBadge      Boolean            @default(false)
  rating          Decimal?           @db.Decimal(3, 2)
  reviewCount     Int                @default(0)

  // Availability — { days: [1..7 mon-sun], startHour: 0-23, endHour: 1-24, timezone: 'Asia/Karachi' }
  // null = always available (the default for newly-onboarded doctors).
  availability Json?

  // Doctor optionally belongs to a clinic (B2B model).
  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id])

  appointments Appointment[]
  reviews      Review[]

  @@index([clinicId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  expires      DateTime
}

model MedicalRecord {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  type       String
  title      String
  content    String   @db.Text
  fileUrl    String?
  ocrText    String?  @db.Text
  recordedAt DateTime
  createdAt  DateTime @default(now())

  @@index([patientId, recordedAt(sort: Desc)])
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  patient     Patient           @relation(fields: [patientId], references: [id])
  doctorId    String?
  doctor      Doctor?           @relation(fields: [doctorId], references: [id])
  status      AppointmentStatus @default(SCHEDULED)
  scheduledAt DateTime
  completedAt DateTime?
  cancelledAt DateTime?

  voiceFileUrl     String?
  transcript       String?  @db.Text
  aiSummary        String?  @db.Text
  severityScore    Int?
  severityLevel    SeverityLevel?
  department       String?

  prescriptionUrl  String?
  prescriptionText String?  @db.Text

  escrow    Escrow?
  note      ConsultationNote?
  review    Review?

  // Null until the 1h-before SMS/email reminder has been sent (idempotency lock for the cron).
  reminderSentAt DateTime?

  // Explicit patient consent for recording (PMDC / telemedicine compliance).
  // Token route refuses to mint a Twilio video grant while this is null.
  recordingConsentAt DateTime?

  // Cancellation metadata — populated only when status transitions to CANCELLED/REFUNDED.
  cancellationReason String?
  cancelledBy        String?   // 'PATIENT' | 'DOCTOR' | 'ADMIN' | 'SYSTEM'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([doctorId])
}

model Review {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient     @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        Doctor      @relation(fields: [doctorId], references: [id])
  rating        Int         // 1..5, enforced at app + DB-CHECK level
  comment       String?     @db.Text
  createdAt     DateTime    @default(now())

  @@index([doctorId, createdAt(sort: Desc)])
}

model ConsultationNote {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  transcript    String      @db.Text
  subjective    String      @db.Text
  objective     String      @db.Text
  assessment    String      @db.Text
  plan          String      @db.Text
  icdHints      String[]
  language      String      @default("en")
  modelUsed     String?
  approvedAt    DateTime?
  approvedBy    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Escrow {
  id                    String       @id @default(cuid())
  appointmentId         String       @unique
  appointment           Appointment  @relation(fields: [appointmentId], references: [id])
  amount                Decimal      @db.Decimal(10, 2)
  currency              String       @default("PKR")
  status                EscrowStatus @default(HELD)
  stripePaymentIntentId String       @unique
  heldAt                DateTime     @default(now())
  releasedAt            DateTime?
  refundedAt            DateTime?
  refundReason          String?
  // Partial-refund support: null until first refund, then the running total in PKR.
  refundedAmount        Decimal?     @db.Decimal(10, 2)
}

model MedicalResource {
  id          String   @id @default(cuid())
  name        String
  type        String
  address     String
  latitude    Decimal  @db.Decimal(10, 8)
  longitude   Decimal  @db.Decimal(11, 8)
  phone       String?
  isAvailable Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}
