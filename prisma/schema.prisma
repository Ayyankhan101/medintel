// Production schema — PostgreSQL
// To deploy: copy this file over schema.prisma, set DATABASE_URL to your PostgreSQL URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AppointmentStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

/// Audit trail for security-sensitive actions: escrow release/refund,
/// prescription upload, KYC/KYD outcomes, doctor verification decisions,
/// appointment cancellations. Required for dispute resolution.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?           // user.id of whoever performed the action; null = system
  actorRole  String?           // PATIENT | DOCTOR | ADMIN | SYSTEM
  action     String            // e.g. "escrow.release", "kyd.approve"
  entityType String            // e.g. "Appointment", "Doctor"
  entityId   String
  metadata   Json?             // small structured context (amounts, reason, IP)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
}

enum SeverityLevel {
  ROUTINE
  URGENT
  CRITICAL
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

model User {
  id            String             @id @default(cuid())
  email         String             @unique
  phone         String             @unique
  passwordHash  String
  name          String?
  role          UserRole
  cnicNumber    String?            @unique
  medIntelCode  String?            @unique
  kycStatus     VerificationStatus @default(PENDING)
  kycVerifiedAt DateTime?
  emailVerified        DateTime?
  emailVerifyToken     String?   @unique
  emailVerifyExpires   DateTime?
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  patient  Patient?
  doctor   Doctor?
  sessions Session[]
}

model Patient {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  dateOfBirth      DateTime?
  gender           String?
  address          String?
  emergencyContact String?

  medicalRecords MedicalRecord[]
  appointments   Appointment[]
  triages        Triage[]
}

model Triage {
  id            String        @id @default(cuid())
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id])
  transcript    String        @db.Text
  summary       String        @db.Text
  severityScore Int
  severityLevel SeverityLevel
  department    String
  voiceFileUrl  String?
  createdAt     DateTime      @default(now())

  @@index([patientId, createdAt(sort: Desc)])
}

model Doctor {
  id              String             @id @default(cuid())
  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id])
  licenseNumber   String             @unique
  specialization  String
  qualifications  String[]
  yearsExperience Int
  bio             String?
  consultationFee Decimal            @db.Decimal(10, 2)
  stripeAccountId String?
  kydStatus       VerificationStatus @default(PENDING)
  kydTier1At      DateTime?
  kydTier2At      DateTime?
  kydTier3At      DateTime?
  trustBadge      Boolean            @default(false)
  rating          Decimal?           @db.Decimal(3, 2)
  reviewCount     Int                @default(0)

  // Availability — { days: [1..7 mon-sun], startHour: 0-23, endHour: 1-24, timezone: 'Asia/Karachi' }
  // null = always available (the default for newly-onboarded doctors).
  availability Json?

  appointments Appointment[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  expires      DateTime
}

model MedicalRecord {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  type       String
  title      String
  content    String   @db.Text
  fileUrl    String?
  ocrText    String?  @db.Text
  recordedAt DateTime
  createdAt  DateTime @default(now())

  @@index([patientId, recordedAt(sort: Desc)])
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  patient     Patient           @relation(fields: [patientId], references: [id])
  doctorId    String?
  doctor      Doctor?           @relation(fields: [doctorId], references: [id])
  status      AppointmentStatus @default(SCHEDULED)
  scheduledAt DateTime
  completedAt DateTime?
  cancelledAt DateTime?

  voiceFileUrl     String?
  transcript       String?  @db.Text
  aiSummary        String?  @db.Text
  severityScore    Int?
  severityLevel    SeverityLevel?
  department       String?

  prescriptionUrl  String?
  prescriptionText String?  @db.Text

  escrow    Escrow?
  note      ConsultationNote?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([doctorId])
}

model ConsultationNote {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  transcript    String      @db.Text
  subjective    String      @db.Text
  objective     String      @db.Text
  assessment    String      @db.Text
  plan          String      @db.Text
  icdHints      String[]
  language      String      @default("en")
  modelUsed     String?
  approvedAt    DateTime?
  approvedBy    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Escrow {
  id                    String       @id @default(cuid())
  appointmentId         String       @unique
  appointment           Appointment  @relation(fields: [appointmentId], references: [id])
  amount                Decimal      @db.Decimal(10, 2)
  currency              String       @default("PKR")
  status                EscrowStatus @default(HELD)
  stripePaymentIntentId String       @unique
  heldAt                DateTime     @default(now())
  releasedAt            DateTime?
  refundedAt            DateTime?
}

model MedicalResource {
  id          String   @id @default(cuid())
  name        String
  type        String
  address     String
  latitude    Decimal  @db.Decimal(10, 8)
  longitude   Decimal  @db.Decimal(11, 8)
  phone       String?
  isAvailable Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}
