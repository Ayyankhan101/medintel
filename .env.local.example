# ─── Required for demo (SQLite, no external DB needed) ─────────────────────────
DATABASE_URL="file:./prisma/dev.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-any-32-char-random-string"

# ─── AI (Groq = free, recommended for demo) ────────────────────────────────────
GROQ_API_KEY="your-groq-api-key"
# GROQ_BASE_URL="https://api.groq.com/openai/v1"   # default, no need to set

# ─── Optional: OpenAI fallback (used if GROQ_API_KEY is not set) ───────────────
# OPENAI_API_KEY="sk-..."

# ─── Payments — skip for demo, required for live escrow ───────────────────────
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PLATFORM_ACCOUNT_ID="acct_..."

# ─── Video calls — skip for demo, required for live consultations ──────────────
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_API_KEY_SID="SK..."
# TWILIO_API_KEY_SECRET="..."

# ─── File storage — skip for demo, required for voice/prescriptions ────────────
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_REGION="ap-south-1"
# AWS_S3_BUCKET="medintel-uploads"

# ─── Maps — optional, mock data used if not set ────────────────────────────────
# GOOGLE_MAPS_SERVER_KEY="AIza..."
# NEXT_PUBLIC_GOOGLE_MAPS_KEY="AIza..."
